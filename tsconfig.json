{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@services/*": ["src/services/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@config/*": ["src/config/*"],
      "@utils/*": ["src/utils/*"],
      "@setup/*": ["src/setup/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "mock/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
