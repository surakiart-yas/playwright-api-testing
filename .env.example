# Template env file. The defaults below run the whole suite OFFLINE against the bundled
# mock (mock/server.ts, started automatically by Playwright's webServer) — a fresh clone
# needs NO secrets and NO network. Copy to `.env` (or `.env.<TEST_ENV>`) to override.
#
# To point at a real API instead: set BASE_URL to its endpoint (never commit a real host)
# and add whatever credentials your provisioner needs — see .claude/rules/fixtures.md.

# === Endpoint ===
# Default = the bundled mock. Playwright only starts the mock when BASE_URL points at
# localhost:8787 (see playwright.config.ts webServer).
BASE_URL=http://localhost:8787

# === Runner ===
# Two-tier response-time budget (see docs/decisions.md §20). Over TARGET → a non-failing
# "slow response" warning in the report; over CEILING → the call FAILS (reads as a hang,
# not jitter). Keep CEILING well above TARGET on shared infra so functional tests aren't
# red'd by latency spikes.
RESPONSE_TARGET_MS=5000
RESPONSE_CEILING_MS=15000
WORKERS=4
# Set to `true` for verbose HTTP logging during test development.
DEBUG_API=false
# Mask secret-looking fields (password / token / Authorization) in logs + Allure attachments.
# Unset = reveal locally but mask in CI (the report is uploaded / shared). Force with true / false.
# MASK_SECRETS=
