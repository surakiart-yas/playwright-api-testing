# Template env file. Copy to `.env` (or `.env.<TEST_ENV>`) and fill in values.
# The suite targets the GoRest public practice API (https://gorest.co.in/public/v2) by
# default — all tests that need a token skip gracefully when GOREST_TOKEN is unset.
#
# To point at a different API: set BASE_URL to its endpoint (never commit a company host)
# and add whatever credentials your provisioner needs — see .claude/rules/fixtures.md.

# === Endpoint ===
BASE_URL=https://gorest.co.in/public/v2

# === GoRest credentials ===
# Personal Bearer token (free: log in at https://gorest.co.in/consumer/login → API tokens).
# When unset, ALL GoRest tests skip — no network calls and no failures in CI.
GOREST_TOKEN=

# === Runner ===
# Two-tier response-time budget (see docs/decisions.md §20). Over TARGET → a non-failing
# warning in the report; over CEILING → the call FAILS (reads as a hang, not jitter).
# Increase CEILING for slow / far networks (e.g. CI hitting a remote API).
RESPONSE_TARGET_MS=5000
RESPONSE_CEILING_MS=15000
WORKERS=4
# Set to `true` for verbose HTTP logging during test development.
DEBUG_API=false
